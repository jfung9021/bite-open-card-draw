# Public app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase public browser-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Never expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth. Store a hash, not a plaintext password.
# Supported local hash format: scrypt:v1:<salt_hex>:<hash_hex>
ADMIN_PASSWORD_HASH=

# Server-side session signing secret.
SESSION_SECRET=

# Optional local settings
NODE_ENV=development
